<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pro Collaborative Board</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
</head>
<body>
    
    <div class="main-container">
        <div class="canvas-area">
            <div class="toolbar">
                <div class="color-picker">
                    <div class="color selected" style="background: #000000;" data-color="#000000"></div>
                    <div class="color" style="background: #e74c3c;" data-color="#e74c3c"></div>
                    <div class="color" style="background: #3498db;" data-color="#3498db"></div>
                    <div class="color" style="background: #2ecc71;" data-color="#2ecc71"></div>
                </div>
                <div class="divider"></div>
                <div class="brush-controls">
                    <input type="range" id="brushSize" min="1" max="50" value="3">
                    <select id="brushShape">
                        <option value="round">Round</option>
                        <option value="square">Square</option>
                        <option value="butt">Flat</option>
                    </select>
                </div>
                <div class="divider"></div>
                <button id="undoBtn" class="secondary-btn">Undo</button>
                <div class="divider"></div>
                <div class="export-group">
                    <select id="exportFormat">
                        <option value="png">PNG</option>
                        <option value="jpeg">JPEG</option>
                        <option value="pdf">PDF</option>
                    </select>
                    <button id="downloadBtn" class="download-btn">Download</button>
                </div>
                <div class="divider"></div>
                <button id="clearBtn">Clear</button>
            </div>
            <canvas id="whiteboard"></canvas>
        </div>

        <div class="chat-sidebar">
            <div class="chat-header">Group Chat</div>
            <div id="chat-messages"></div>
            <form id="chat-form">
                <input type="text" id="chat-input" placeholder="Say something..." autocomplete="off">
                <button type="submit">Send</button>
            </form>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/canvas.js"></script>
</body>
</html>